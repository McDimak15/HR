Configs: {
	ServerConfig: {
		DisplayName: Серверная конфигурация

		Headers: {
			MainCategory: Основное
			WeaponChanges: Изменение оружий
			ArmorChanges: Изменение брони
			ModChanges: Изменения модов
			// AccessoryChanges: Accessory Changes
		}

		EnableBossScaling: {
			Label: "[i:ContinentOfJourney/SolarFlareScoria] Изменение характеристик боссов"
			Tooltip: Если эта функция включена, характеристики боссов HWJ будут изменятся в зависимости от установленных модификаций.
		}

		HWJRecipes: {
			Label: "[i:ContinentOfJourney/FinalBar] Изменения рецептах HWJ"
			Tooltip: Если эта функция включена, балансирует рецепты HWJ чтобы они соответствовали прогрессии других модов.
		}

		PermanentToAccessories: {
			// Label: "[i:ContinentOfJourney/TheSwitch] Переработка переключателя"
			// Tooltip: Если эта функция включена, переключатель будет переработан в виде аксессуара.
		}

		EnableBookmarks: {
			Label: "[i:ContinentOfJourney/EruditeBookmark] Включить закладки"
			Tooltip: Если эта функция включена, модовое оружие мага будет работать со страницами заклинаний.
		}

		EnableTickets: {
			 Label: "[i:ContinentOfJourney/LegacyTicket] Балансировка билетиков"
			 Tooltip: Если эта функция включена, баланс билетиков удачи для метателя будет сбалансирован в соответствии с другими модами.
		}

		CustomContent: {
			Label: "[i:HomewardRagnarok/RogueBadge] Пользовательский контент мода"
			Tooltip: Если эта функция включена, добавляет новый контент который заполняет пробелы в прогрессии.
		}

		BloodOrbPotions: {
			Label: "[i:CalamityMod/BloodOrb] Дубликация зелий с помощью кровавых сфер"
			Tooltip: Если эта функция включена, можно дублировать зелья HWJ с помощью кровавых сфер каламити.
		}

		CustomStealthStrikes: {
			Label: "[i:ContinentOfJourney/RisingAction] Скрытые удары HWJ"
			Tooltip: Если эта функция включена, некоторые оружия HWJ получат возможность наносить скрытые удары
		}

		EnableRogueClassChanges: {
			Label: "[i:ContinentOfJourney/Fission] Объединение с метателем"
			Tooltip: Если эта функция включена, метательное оружие HWJ будет изменено на класс метателя.
		}

		EnableMeleeClassChanges: {
			Label: "[i:ContinentOfJourney/Shoreline] Объединение с воином"
			Tooltip: Если эта функция включена, некоторые оружие HWJ будут изменены на класс воина.
		}

		EnableHealerClassChanges: {
			Label: "[i:ContinentOfJourney/DaCapo] Объединение с целителем"
			Tooltip: Если эта функция включена, косы HWJ будут изменены на класс целителя.
		}

		WeaponBalancing: {
			Label: "[i:ContinentOfJourney/StarEaterStaff] Балансировка оружия"
			Tooltip: Если эта функция включена, баланс оружия HWJ будет сбалансирована в соответствии с другими модами.
		}

		ArmorBalancing: {
			Label: "[i:ContinentOfJourney/WatchmanHat] Armor Balancing"
			Tooltip: Если эта функция включена, баланс брони HWJ будет сбалансирован в соответствии с другими модами.
		}

		ArmorCraft: {
			Label: "[i:ContinentOfJourney/EquilibriumBreastplate] Рецепты брони"
			Tooltip: Если эта функция включена, рецепты брони HWJ будут объединены с рецептами других модов.
		}

		CalamityBalance: {
			Label: Поддержка каламити
			Tooltip: Если эта функция включена, объединяет аксессуары, оружия и рецепты с HWJ.
		}

		ClamityBalance: {
			Label: Поддержка кламити
			Tooltip: Если эта функция включена, объединяет некоторые оружия и аксессуары кламити с HWJ.
		}

		ThoriumBalance: {
			Label: Поддержка ториума
			Tooltip: Если эта функция включена, объединяет некоторые аксессуары и рецепты целителя из ториума с HWJ, так же поддерживает аддоны на ториум.
		}

		SOTSBalance: {
			Label: Поддержка SOTS
			Tooltip: Если эта функция включена, изменяет рецепты SOTS и Unofficial SOTS Bard,Thrower and Healer.
		}

		ConsolariaBalance: {
			Label: Поддержка консоларии
			Tooltip: Если эта функция включена, объединяет эссенции отравления из консоларии и HWJ
		}
	}
}

