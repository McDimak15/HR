			'''
	}

	Horizon: {
		Remove: "'Воздух поднимает вас вверх'"
		HoldShift: Удерживайте Shift для просмотра дополнительной информации
		DefaultStats:
			'''
			Время полёта: 3.75 секунды
			Максимальная горизонтальная скорость: 52 км
			Максимальная вертикальная скорость: 100 км
