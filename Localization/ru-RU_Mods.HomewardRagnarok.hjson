			Призывает жизненосца
			Можно использовать в любом биоме
			'''
	}

	RogueBadge: {
		DisplayName: Значок великого вора
		Tooltip:
			'''
			Увеличивает разбойный урон на 20%
			Увеличивает шанс разбойного критического урона на 5%
			'''
	}

	BrokenChest: {
		DisplayName: Сломаный хребет
		Tooltip:
			'''
			Призывает материализатора
			Можно использовать в любом биоме
			'''
	}

	EternalClock: {
		DisplayName: Вечные часы
		Tooltip:
			'''
			Призывает часового
			Можно использовать в любом биоме
			'''
	}

	ScarabIdol: {
		DisplayName: Идол скарабея
		Tooltip:
			'''
			Призывает веру скарабея
			Можно использовать в любом биоме
			'''
	}

	HerbalistPouch: {
		DisplayName: Набор травника
		Tooltip:
			'''
			Атаки йо-йо накладывают дебафф «Обжигающий холод» и «Отравление» и могут заморозить врагов
			При нанесении урона врагу йо-йо даёт вам 10% сопротивление урону, пока вы не получите урон
			Этот эффект перезарежается в течении 15 секунд с момента получения урона
			Ударяя врагов с помощью йо-йо, вы заряжаете щит из листьев
			Щит полностью заряжается после нанесения 10 ударов
			Щит уменьшает получаемый урон до 21%
			Щит выпускается при прекращении атаки
			'''
	}

	EvilFlask: {
		DisplayName: Злой флакон
		Tooltip:
			'''
			20% шанс не потратить боеприпысы при использовании огнемётов
			Позволяет вам изменять снаряд вашего огнемёта
			Ваш огнемёт накладывает дебафф «Гниение мозга»
			При экиперовке показываются предметы которые можно использовать
			Вы можете вставить лишь 2 ингридиента
			'''
	}

	TimelessFountain: {
		DisplayName: Вневременной фонтан
		Tooltip: Считается за фонтан жизни, фонтан материи, фонтан времени
	}

	NegablastShield: {
		DisplayName: Щит нега-взрыва
		Tooltip:
			'''
			50 базоваго урона
			Немного увеличивает продолжительность неуязвимости после получаения урона
			Увеличивает получаемое отбрасывание
			Создаёт взрыв при получении урона
			Даёт невосприимчивость к отбрасыванию и враги чаще выбирают вас в качестве цели
			Получаемый урон снижен на 10%
			Каждые 3 секунды при получении урона вокруг вас происходит мощный взрыв
			Урон взрыва зависит от вашей защиты
			'''
	}

	BabyOil: {
		DisplayName: Детское масло
		Tooltip:
			'''
			При получении урона из игрока выпадают 3-5 капель масла
			Выпавшее масло наносит урон врагам
			'''
		Contributor: - Предмет разработчика -
	}

	TheBibleOfTheThrowerVol4: {
		DisplayName: Библия метания: Том IV
		Tooltip:
			'''
			Увеличивает метательный урон на 20%
			Увеличивает скорость полёта расходуемых метательных снарядов на 50%
			При использовании расходуемовых оружий вы машите битой
			   Три метательных кольца усиливают ваши метательные оружия
			Уменьшает время использования расходуемовых метательных оружий на 20%
			Когда вы держите в руках метательное оружие, ускорение бега увеличивается на 75%
			Наносит дополнительный удар в размере 17.5% метательного урона
			'''
		NoExhaustion: При экипировке оружие больше не изматывает вас
	}

	DeluxeDewCollector: {
		DisplayName: Собиратель росы делюкс
		Tooltip:
			'''
			Лечение союзника даёт ему 2 единицы восполнения здоровья и создаёт росу
			Поднятие росы увеличивает ваше собственное восполнение здоровья на 4 единицы
			Исцеляющие заклинания будут восстанавливать дополнительно 6 единицы здоровья
