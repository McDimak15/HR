		 '''
	}

	RiftGenerator: {
		 DisplayName: Генератор разломов
		 Tooltip:
			'''
			Увеличивает максимальное количество миньонов и стражей на 1
			Создает 4 платформы слева и справа от вас
			Вы можете перетаскивать платформы, щелкнув правой кнопкой мыши, но они всегда будут оставаться симметричными
			Позволяет призывать стражей на платформах
			После убийства врага, атаки миньонов и стражей на короткое время наносят дополнительно 2 ед. урона
			Призывает минога-пожирателя позади вас
			'''
	}

	Lore: {
		LoreBigDipper: {
			DisplayName: История (Большая Медведица)
			Tooltip: ""
			Lore:
				'''
				Мой главный учёный лишь однажды рассказал мне о своём прошлом. О том, как он проснулся в лаборатории,
				окруженный передовыми технологиями, в конце концов он присоединился к мне, создавая боевых машин, и всё это во имя прогресса 
				Я поднимаю этот вопрос, потому что Дрэйдон прямо сказал мне, что этот спутник не принадлежит ему
				Насколько нам удалось выяснить, это был спутник связи, способный передавать координаты подробной карте местности
				К сожалению, на самой карте показаны только те места, нанесенные на карту столетия назад
				Дрэйдон уже проанализировал всё, что мог, об этом спутнике, создав для себя более совершенные модели
				Хотя сам по себе он не представляет никакой ценности, он служит ярким напоминанием о том,
				что если кто-то с огромным трудом создал Дрэйдона, кто может сказать, что не может существовать других, столь же совершенных творений?
				'''
		}

		LoreDiver: {
			DisplayName: История (Дайвер)
			Tooltip: ""
			Lore:
				'''
				Межпространственный портал, ведущий в сердце альтернативной вселенной... неудивительно, что привело это место к разрушению
				Многие организации были созданы с целью достижения и изучения любых альтернативных измерений, с которыми они случайно сталкивались,
				особенно когда начали распространяться слухи о Пожирателе
				Ни одной из этих организаций больше не существует
				Это чудовище - прекрасный пример того, как выглядит конечная цель межпространственных исследований: 
				быть замеченным высшей тьмой, что принесет безумие и смерть всем участникам
				В лучшем случае, если заглянуть в реальность под другим углом, можно увидеть место, населенное исключительно простыми существами,
				например, мир разумных птиц, скачущих на гигантских крабах
				...Не спрашивай, откуда я это знаю. Космология - очень странная область науки
				'''
		}

		LoreTrench: {
			DisplayName: История (Впадина)
			Tooltip: ""
			Lore:
				'''
				Ещё одно пятно на побережье, не тронутое богами
				Можно было предположить, что его удаленность от серного моря и отсутствие жизнеспособных входов делают его недоступным для внешнего мира
				Так думали поселенцы этой впадины, используя малоизвестную форму гидромантии, чтобы создать внутри воздушный карман
				Отрезанные от поверхности, они имели всё необходимое для себя время
				Всё, что я знал, это то, что основное развитие здесь происходило в области демонологии,
				известной практики порабощения демонов своей волей и, как ни странно, космологии
				Я всегда скептически относился к тому, как подземное поселение может так много знать о Вселенной, 
				но к тому времени, как Дрэйдон исследовал его, этот город в бездне давно был затоплен и заброшен
				Судя по различным ужасам, которые теперь населяют это место, 
				у меня есть достаточно разумный ответ на мои вопросы о природе и судьбе этих людей
				'''
		}

		LoreGoblinChariot: {
			DisplayName: История (Гоблинская Колесница)
			Tooltip: ""
			Lore:
				'''
				Гоблины как раса на самом деле довольно молоды в масштабах Террарии
				Даже их самые древние поселения довольно новы, чтобы их можно было строить с использованием более современной инфраструктуры
				Об их репутации бандитов больше ничего сказать, кроме того, 
				что уже было упомянуто или очевидно
				Ты удивишься, узнав, что в первый год моих завоеваний племя гоблинов было первой, по настоящему объеденённой фракцией
				Их изобретательность привела к появлению моей первой настоящей поддержки в виде техники, 
				что обеспечило им мою благосклонность, пока один из новых членов моей армии не заменил все их научные разработки своими собственными
				В наше время, должно быть, очень тяжело полагаться на такую ​​устаревшую технику
				'''
		}

		LoreMarquisMoonsquid: {
			DisplayName: История (Маркиз Лунный Кальмар)
			Tooltip: ""
			Lore:
				'''
				Один из бесчисленных океанских хищников, обитающих глубоко под волнами, хотя этот экземпляр, похоже, вырос до необычных размеров
				Лунные кальмары живут только в самых глубоких частях океана, 
				вдали от рыболюдей, с которыми они конкурируют, используя биолюминесценцию для общения друг с другом в полной темноте
				Эти факторы делают появление этого зверя на поверхности странным явлением 
				Какие любопытные изменения... что же должно было произойти в этой бездне, чтобы мутировать это несчастное существо и вытолкнуть его на поверхность?
				'''
		}

		LoreOverwatcher: {
			DisplayName: История (Часовой)
			Tooltip: ""
			Lore:
				'''
				Бог времени был нелюдимым
				Когда человек может видеть прошлое и будущее будто бы слева и справа, это открывает гораздо, гораздо больший диапазон мест для уединения
				Настолько большой, что я до сих пор не понимаю, как он собрал своих последователей
				Единственный способ добраться до него - найти одного последователя, избить его до полусмерти, чтобы он привёл меня к своему идолу
				Как только он оказался предо мной-
				(Шепот на мгновение затих. Часть истории потеряна?)
				-Оставив меня посреди пустыни. Все мои усилия закончились лишь бессмысленными словами. Какая пустая трата времени...
				'''
		}

		LorePriestessRod: {
			DisplayName: История (Жрица Стержней)
			Tooltip: ""
			Lore:
				'''
				Это, безусловно, одно из самых странных строений тела, 
				крылья Небесных Жезлов, похожие на пропеллеры, позволяют им стремительно перемещаться по небу быстрее любого другого летающего существа, 
				или, по крайней мере, тех, кто обитает в нашем мире
				Самый ужасающий аспект Небесных Жезлов - это их способ питания
				Этот вид не питается твердой пищей, вместо этого обладая уникальной способностью пожирать души живых напрямую
				Это также означает, что они могут питаться душами внутри машин, к большому разочарованию Дрэйдона
				Оказывается, стальные солдаты, питаемые душами, обладают большей вместительностью, чем большинство существ, обитающих в атмосфере
				Мне приходилось разрабатывать контрмеры против этого неожиданного врага чаще, чем хотелось бы признать
				Некоторые из них даже значительно увеличились в размерах благодаря огромному количеству душ, 
				что, в свою очередь, делает Жрицу Стержней угрозой для всего, чему мои солдаты могли противостоять
				'''
		}

		LorePuppetOpera: {
			DisplayName: История (Кукольная Опера)
			Tooltip: ""
			Lore:
				'''
				Кажется нереальным видеть, во что превратился этот театр, ведь я бывал здесь в лучшие времена
				Я едва мог разглядеть, то, с чем ты сражался во тьме
				Этот деревянный лабиринт когда-то был местом бурной культуры, защищенным от нападающих постоянно меняющимися стенами
				Театр был его сердцем, самым известным своими экстравагантными кукольными представлениями, которые только можно было найти,
				которые, как известно, часто посещал архимаг
				Когда мой крестовый поход угас, я закрыл глаза на это место. Я ожидал, что оно будет в лучшем случае заброшено, но это... 
				Когда-то это было место уединения. Теперь же оно, кажется, притягивает ужасы мира
				Я могу только представить, что случилось с его бывшими жителями... если они еще живы
				'''
		}

		LoreScarabBelief: {
			DisplayName: История (Вера Скарабея)
			Tooltip: ""
			Lore:
				'''
				Бог мифов был загадкой
				Противоречивые истории поражают даже самые старые библиотеки Террарии, основанные исключительно на словах его последователей 
				Назвать этих последователей чрезмерным рвением было бы преуменьшением, они поклонялись самой идее поклонения
				У каждого верующего есть своя версия Скарабея, которую он, как утверждает, ясно видит, и двух одинаковых не бывает,
				они сильно различаются даже внутри одной группы. Весь образ веры в Скарабея состоит из лжи и заблуждений, 
				включая бессмысленные ритуалы, где-
				(Шепот на мгновение затих. Часть истории потеряна?)
				-это всего лишь концепция материальной формы, существующая лишь как идея, обитающая в умах своих последователей
				Как это отвратительно. Даже Провиденс никогда не переступала эту границу. Надеюсь, это извращение веры навсегда останется забытым
				'''
		}

		LoreSlimeGod: {
			DisplayName: История (Сльзь Божественности)
			Tooltip: ""
			Lore:
				'''
				Бог слизней был разделён
				Возможно, ты уже знакомы с сущностью, которую я называл «Богом слизней»
				Это название не совсем неверно... хоть и довольно обманчиво
				Хотя он и является богом сам по себе, считается, что все слизни изначально произошли от единого, «истинного» бога слизней
				и в конечном итоге вернутся к нему после смерти
				Информация об этом существе за пределами его места жительства туманна, оно существует либо внутри, 
				либо, возможно, как сам первозданный свет 
				Насколько он и солнце Зератроса - одно и то же существо, - это вопрос, который лучше оставить для ученых, но я могу сказать тебе-
				(Шепот на мгновение затих. Часть истории потеряна?)
				-не могу представить себе, какой силы он обладал бы, если бы без ограничений поглощал всю слизь
				Тогда у тебя, скорее всего, не было бы ни единого шанса
				'''
		}

		LoreTheLifebringer: {
			DisplayName: История (Жизненосец)
			Tooltip: ""
			Lore:
				'''
				Бог жизни был всеобъемлющим
				Слишком обширная область, чтобы лишь одна ауритовая душа могла обладать полной властью над ней
				Сама Сильва обладала властью лишь над концепцией жизни, поскольку природа была слишком разнообразна, чтобы она могла её контролировать
				Кажется, что Жизненосец обладала более «полной» властью над природными бедствиями, а не только над эволюцией или выживанием
				Главное отличие от Сильвы заключалось в том, что- 
				(Шепот на мгновение затих. Часть истории потеряна?)
				-потому что ей не поклонялись традиционным способом, не было ни храмов, ни статуй, ни даже письменных источников, посвященных ей 
				У меня не было никаких зацепок, и я не мог оправдать бесцельные поиски, поэтому я отложил их до тех пор, пока не найду лучший способ
				Излишне говорить, что его я так и не нашёл
				'''
		}

		LoreTheMaterealizer: {
			DisplayName: История (Материализатор)
			Tooltip: ""
			Lore:
				'''
				Бог материи был исполнительным
				Как нынешний хранитель материальных законов нашего мира, по сути, его строительными блоками
				Он так же холоден и расчетлив, как того и требуется. Получив задание, он выполнит его до мельчайших деталей
				То же самое относится и к его последователям, которые выступали в роли наемных строителей для различных фракций
				Заплатив им плату, вы не найдете памятника лучше, от возвышающихся статуй в Ильмерисе до того самого храма, который Провиденс называет своим домом
				Их нейтралитет позволил мне легко подобраться к ним под предлогом выполнения поручения, что привело меня к спиральной-
				(В уши проникает громкий статический шум, шёпот неслышен, он продолжается без перерыва. Кто-то мешает?)
				-Мне потребовалось до смешного много времени, чтобы найти выход. После этого я просто вернулся домой и... задумался
				'''
		}

		LoreTheMotherbrain: {
			DisplayName: История (Материнский мозг)
			Tooltip: ""
			Lore:
				'''
				На какое-то время я забыл о существовании данной машины
				Дрэйдону было поручено создать эту оболочку по поручению культа драконов
				построенную лишь для того, чтобы занять место тюремщиков, чьи души были использованы при её создании
				Обладая гораздо более высоким интеллектом, она также служила экспериментом в области псионических технологий,
				возможность запирать любых непокорных заключенных в виртуальном мире, созданном для пыток и наказаний 
				Запрос требовал надзирателя, но получилось устройство пыток
				Когда души в темнице стали беспокойными, Дрэйдон был вынужден оставить её за этими проклятыми стенами 
				Я понимал, что его это раздражает, но он почти не жаловался, уже переходя к следующему проекту 
				В то время как всё вокруг рушилось, потерянная машина,
				не осознавая, что мой крестовый поход уже подошёл к концу, стала лишь напоминанием о моей ужасной, кровавой истории
				'''
		}

		LoreTheSon: {
			DisplayName: История (Сын)
			Tooltip: ""
			Lore:
				'''
				Когда боги заявили о своих правах на этот мир,
				их действия вызвали волнения среди первобытных сил, обитающих высоко в небесах
				Был тот, кто утверждал, что является прямым потомком высшей власти нашей вселенной, 
				обличая их преступления против Террарии
				Сила, которой обладал этот полусмертный, подобие истинного божественного, была поразительной, 
				одарённый философским складом ума, он оказался в авангарде крестового похода, предшествовавшего моему рождению
				К сожалению, как только он начал своё движение... в дело вмешался Ноксус
				Всё, что связано с этим именем, искажено само по себе,
				но я могу с достаточной уверенностью подтвердить, что он сыграл ключевую роль в распятии Сына
				Возможно, его план был напрямую подорван самим существованием Сына
				Я узнал обо всём этом только тогда, когда активировал ту же структуру, которую ты неосознанно активировал, чтобы-
				(Внешнее влияние заглушает шёпот… затем вы слышите грохот)
				Думаю, этого достаточно
				'''
		}

		LoreWallofShadow: {
			DisplayName: История (Стена Теней)
			Tooltip: ""
			Lore:
				'''
				Чередующиеся узоры теней и сухожилий, вытянутые конечности, чтобы накормить его голодные глаза, 
				запах смерти, витавший в воздухе... Я бы узнал эту магию где угодно
				Это, несомненно, поразительно похоже на то создание, которое я использовал для пленения сущностей богов
				Я сильно сомневаюсь, что создатели вообще знали обо мне, просто сосредоточившись на решении для сдерживания пришельцев из других миров, выходящих из их порталов
				Провал их плана был прост: создатели не учли, что их тюрьма неизбежно переполнится
				К тому моменту, когда первобытные тени начали просачиваться сквозь кирпичную кладку, было уже слишком поздно
				Она превратилась в бомбу замедленного действия, наполненную сущностями из бесчисленных измерений, изученных за всю жизнь города
				С этим взрывом красок, который ты был вынужден обрушить на этот мир, скоро боги обратят на вас свой взор
				Как только они решат действовать, вы будете знать, что делать
				'''
		}

		LoreWhale: {
			DisplayName: История (Вечно Падающий Кит Конца Света)
			Tooltip: ""
			Lore:
				'''
				Бог смерти был ироничен
				Из всех тех, кто мог бы взять на себя роль жнеца, 
				из всех ужасов, которые могли бы использовать свою силу для воцарения смерти, потенциально даже над всемогущим предателем...
				этот титул достался киту. Хотя он и не глуп, по поведению он гораздо ближе к настоящему животному, 
				действуя с невинностью, в которой и кроется его поистине ужасающая сила
				Легенды о Вечнопадающем Ките сохранилась в основном благодаря тому, что её передавали из уст в уста моряки,
				привлекая безрассудных путешественников, пытавшихся, в конечном итоге, потерпеть неудачу, в попытке завладеть его силой
				Я раздумывал, стоит ли верить этим неподтвержденным свидетельствам, в конце концов придя к-
				(Шепот на мгновение затих. Часть истории потеряна?)
				- в итоге, я признаю кита продуктом обстоятельств и ничем иным
				Я никогда не смог бы оправдать поклонение ему, но есть гораздо худшие преступления, чем желание, чтобы его оставили в покое
				'''
		}
	}

