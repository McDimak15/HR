	HerbalistPouch: {
		DisplayName: Набор травника
		Tooltip:
			'''
			Атаки йо-йо накладывают дебафф «Обжигающий холод» и «Отравление» и могут заморозить врагов
			При нанесении урона врагу йо-йо даёт вам 10% сопротивление урону, пока вы не получите урон
			Этот эффект перезарежается в течении 15 секунд с момента получения урона
			Ударяя врагов с помощью йо-йо, вы заряжаете щит из листьев
			Щит полностью заряжается после нанесения 10 ударов
			Щит уменьшает получаемый урон до 21%
			Щит выпускается при прекращении атаки
			'''
	}

	EvilFlask: {
