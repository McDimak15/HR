	}

	Edgewalker: {
		EdgeCrit: Увеличивает шаес критического урона на 6%
		EdgeRocket: Даёт пользователю мастерство в использовании ракетниц
	}

	VanguardBreastpiece: {
		Remove1: Даёт невосприимчивость к отбрасыванию
		Remove2: Немного увеличьте время неуязвимости
		OrigTooltip1: Даёт невосприимчивость к горению и большинству дебафов
		Replace1: Даёт невосприимчивость к большинству дебафов, отбрасыванию и горению
		Sots1: Окружает вас 4 орбитальными снарядами
		Sots2: Отбрасывает атакующих врагов от вас с помощью метательных копий
		Sots3: Увеличивает прирост пустоты на 2, регенерацию здоровья на один
		Sots4: уменьшает получаемый урон на 7% и увеличивает шанс критического удара на 4%
		Sots5: Снаряды отключаются, когда скрыты
		Thorium1: Перенаправляет на владельца щита 25% урона, нанесённого игрокам вашей команды, если здоровье игрока выше 25%
		Thorium2: Когда здоровье ниже 25%, значительно ускоряет регенерацию здоровья и увеличивает защиту
	}

	GrayRook: {
		"Remove'UseTime'": -Снижение времени использования оружия на 35%
		OrigTooltip1: -Увеличивает скорость ближнего боя на 2%
		Replace1: Увеличивает вашу
