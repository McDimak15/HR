	HerbalistPouch: {
		DisplayName: Herbalist Pouch
		Tooltip:
			'''
			While equipped, your yoyo damage inflicts frostburn and venom and has a chance to freeze enemies
			Damaging an enemy with a yoyo will grant you 10% damage reduction until you take damage
			This effect must recharge for 15 seconds after protecting you
			Hitting enemies with yoyos charge a leaf shield
			The shield is fully charged in 10 hits
			The shield decreases up to 21% of the next damage you take
			The shield is launched when retrieving the yoyo
			'''
	}

	EvilFlask: {
		DisplayName: Evil Flask
		Tooltip:
			'''
			20% chance to not consume ammo when using a flamethrower
			Allows you to customize the projectile of your flamethrower
			Your flamethrower inflicts Brain Rot debuff
			When equipped, show items that can be inserted
			You can insert 2 ingredients at most
			'''
	}

	TimelessFountain: {
		DisplayName: Timeless Fountain
		Tooltip: Counts as a Fountain of Life, Fountain of Matter, Fountain of Time
	}

	NegablastShield: {
		DisplayName: Negablast Shield
		Tooltip:
			'''
			50 base damage
			Slightly increases length of invincibility after taking damage
			Increases the knockback you receive
			Release an explosion when damaged
			Immune to enemy knockback & enemies are more likely to target you
			Damage taken reduced by 10%
			Every 3 seconds, taking damage will unleash a volatile explosion all around you
			Explosion damage scales with your defense
			'''
	}

	BabyOil: {
		DisplayName: Baby Oil
		Tooltip:
			'''
			When damaged cause 3-5 droplets of oil to drop out from you
			Droplets do damage to enemies
			'''
		Contributor: - Contributor Item -
	}

	TheBibleOfTheThrowerVol4: {
		DisplayName: The Bible of the Thrower: Volume IV
		Tooltip:
			'''
			20% increased thrower damage
			50% increased consumable thrower weapon velocity
			Swing a bat at close range when using consumable weapons
			Three rings will boost the projectiles you throw
			Decrease use time of consumable thrower weapons by 20%
			When holding a thrower weapon, increase acceleration by 75%
			17.5% of your thrower damage is duplicated
			'''
		NoExhaustion: Removes all Exhaustion when equipped
	}

	DeluxeDewCollector: {
		DisplayName: Deluxe Dew Collector
		Tooltip:
			'''
			Healing an ally grants them 2 life recovery and generates dew
			Picking up dew increases your own life recovery by 4
			Healing spells will heal an additional 6 life
			'''
	}

