		Replace2: -鞭子距离增加25%
		MeleeRebalance: -近战武器大小增加25%
		RogueRebalance: -盗贼攻击速度提升10%
		HealerRebalance: -额外治疗量增加1点
		BardRebalance: -最大灵感值增加2点
	}

	BatNecklace: {
