FlamethrowerEx.HomewardRagnarok.SulphuricScaleEffect: 火焰会造成6秒的辐射减益

Configs: {
	ServerConfig: {
		DisplayName: 服务器配置

		Headers: {
			MainCategory: 主要
			WeaponChanges: 武器修改
			ArmorChanges: 盔甲修改
			ModChanges: 模组修改
		}

		EnableBossScaling: {
			Label: "[i:ContinentOfJourney/SolarFlareScoria] Boss数值修改"
			Tooltip: 启用后，旅人归途的Boss数值会根据你启用的模组进行变更
		}

		HWJRecipes: {
			Label: "[i:ContinentOfJourney/FinalBar] 旅人归途配方调整"
			Tooltip: 启用后，旅人归途的配方会被调整以适配其他模组的进程
		}

		EnableBookmarks: {
			Label: "[i:ContinentOfJourney/EruditeBookmark] 启用书签"
			Tooltip: 启用后，模组的魔法武器能够使用魔咒书页
		}

		CustomContent: {
			Label: "[i:HomewardRagnarok/RogueBadge] 自制模组内容"
			Tooltip: 启用后，会添加可以弥补游戏进程空缺的新内容
		}

		BloodOrbPotions: {
			Label: "[i:CalamityMod/BloodOrb] 药水血珠复制"
			Tooltip: 启用后，旅人归途的药水可以使用灾厄血珠进行复制
		}

		CustomStealthStrikes: {
			Label: "[i:ContinentOfJourney/RisingAction] 旅人归途潜伏攻击"
			Tooltip: 启用后，部分旅人归途武器获得潜伏攻击
		}

		EnableRogueClassChanges: {
			Label: "[i:ContinentOfJourney/Fission] 投手职业融合"
			Tooltip: 启用后，旅人归途的可投掷武器会被转换为投手职业
		}

		EnableMeleeClassChanges: {
			Label: "[i:ContinentOfJourney/Shoreline] 近战职业融合"
			Tooltip: 启用后，一些旅人归途的武器会被转换为近战武器
		}

		EnableHealerClassChanges: {
			Label: "[i:ContinentOfJourney/DaCapo] 牧师职业融合"
			Tooltip: 启用后，旅人归途的镰刀会使用瑟银的牧师职业
		}

		WeaponBalancing: {
			Label: "[i:ContinentOfJourney/StarEaterStaff] 武器平衡"
			Tooltip: 启用后，旅人归途的武器会根据其他模组进行重平衡
		}

		ArmorBalancing: {
			Label: "[i:ContinentOfJourney/WatchmanHat] 盔甲平衡"
			Tooltip: 启用后，旅人归途的盔甲会根据其他模组进行重平衡
		}

		ArmorCraft: {
			Label: "[i:ContinentOfJourney/EquilibriumBreastplate] 盔甲配方"
			Tooltip: 启用后，旅人归途的盔甲配方会与其他模组融合
		}

		CalamityBalance: {
			Label: 灾厄支持
			Tooltip: 启用后，灾厄的饰品、武器和配方将会和旅人归途融合
		}

		ClamityBalance: {
			Label: 灾蛤支持
			Tooltip: 启用后，根据旅人归途调整灾蛤的部分饰品和武器
		}

		ThoriumBalance: {
			Label: 瑟银支持
			Tooltip: 启用后，将部分瑟银的牧师饰品和配方与旅人归途融合，瑟银的附属模组同样支持
		}

		SOTSBalance: {
			Label: 暗影奥秘支持
			Tooltip: 启用后，调整暗影奥秘和非官方暗影奥秘吟游诗人、投手&牧师武器的配方
		}

		ConsolariaBalance: {
			Label: Consolaria支持
			Tooltip: 启用后，将旅人归途的枯萎之魂与Consolaria的融合
		}
	}
}

ModCompat.BossChecklist.SlimeGod: 史莱姆之神：再临

ItemTooltips: {
	OmniShield: -至高神盾-
	ImmunityVulnerable: 使你免疫脆弱
	CommemorativeCoin: 减少35%你受到的减益伤害
	TransactionCertificate: 受到致命伤害时将hp锁定为1点，有10分钟冷却时间
	SteamkeeperWatch: 你的哨兵可以永久存在并在2分钟内获得至多15%伤害提升
	HungeringBlossom: 可见性关闭时获得饮魔玫瑰的效果
	ConstructionPDA: 最大哨兵栏数量增加 1 个
	DivineNecklace: 仆从的攻击令敌人沐浴在神的荣光下
	ToggleWings: 在物品栏中按住Shift右键切换 [i:493] 翅膀的效果
	AbyssCore: 鼠标位置发光
	GrandSpectral:
		'''
		延长你的无敌时间
		受伤时召唤光谱追杀敌人
		击中敌人时召唤光谱追杀敌人
		'''
	LampreyScarf:
		'''
		召唤七鳃鳗围巾
		鞭子距离增加10%
		增加1个最大哨兵栏
		'''
	ArmillarySphere: 你的哨兵连结成星座对路径上的敌人造成召唤武器的一半伤害
	"Remove'Range'": 远程
	"Remove'range'": 远程
	SpikyCoverRework: 鞭子尖端造成1.5倍伤害并施加流血
	CrossbowScope:
		'''
		增加5%远程伤害
		增加7%远程暴击率
		降低敌人瞄准你的概率
		提高箭矢的伤害
		将木箭转化为圣箭
		手持枪械时显示一条只有你能看到的子弹轨迹
		'''
	DivineTouch: 近战攻击施加圣火减益
	StarFlower:
		'''
		增加80点最大魔力值
		减少12%魔力消耗
		'''
	Negatama: 释放暗能量，魔力越低伤害越高
	PoisonEffect: 施加中毒减益
	HolyFlamesEffect: 施加圣火减益
	VaporfiedEffect: 施加蒸汽波减益

	Horizon: {
		Remove: “大气将你抬得很高很高”
		HoldShift: 按住Shift以了解更多
		DefaultStats:
			'''
			飞行时间：3.75秒
			最高水平速度：52mph
			最高垂直速度：100mph
			'''
		HidedStats:
			'''
			水平加速度：每秒61.32mph
			垂直加速度：
			每秒42.98mph
			当上升速度低于41mph时：每秒89.21mph
			在下降期间重新上升时：每秒326.38mph
			'''
		RunningAccel: 增加44%奔跑加速度
	}

	CommandersGaunlet: {
		OrigTooltip: 近战攻击速度
		Replace: 鞭子挥舞速度
	}

	Edgewalker: {
		EdgeCrit: 提高6%暴击率
		EdgeRocket: 完善你使用火炮的能力
	}

	VanguardBreastpiece: {
		Remove1: 免疫击退
		Remove2: 略微延长你的无敌时间
		OrigTooltip1: 对着火与大部分减益免疫
		Replace1: 免疫大部分状态减益、击退和火块
		Sots1: 使4个轨道弹幕围绕你
		Sots2: 发射能让攻击者远离你的标枪
		Sots3: 增加2点虚空恢复量和1点生命恢复速度
		Sots4: 降低7%所受伤害，并增加4%暴击率
		Sots5: 隐藏外观时会禁用弹幕
		Thorium1: 高于25%生命值时，可吸收团队附近队友所受伤害的25%
		Thorium2: 低于25%生命值时，你会快速再生生命并增加防御
	}

	GrayRook: {
		"Remove'UseTime'": -物品使用时间减少35%
		OrigTooltip1: 提高2%近战攻速与
		Replace1: 提高
